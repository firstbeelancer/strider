<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Strider.UI.Views.ComposeWindow"
        Title="New Message"
        Width="720" Height="600"
        MinWidth="480" MinHeight="400"
        WindowStartupLocation="CenterOwner">

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Padding="8,6"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Content="📤 Send" Classes="accent" Width="80"/>
                <Separator/>
                <Button Content="💾 Save Draft" Classes="ghost"/>
                <Button Content="📎 Attach" Classes="ghost"/>
                <Separator/>
                <Button Content="✍️ Sign" Classes="ghost" ToolTip.Tip="Toggle signature"/>
                <Button Content="🔒 Encrypt" Classes="ghost" ToolTip.Tip="PGP encrypt"/>
            </StackPanel>
        </Border>

        <!-- Send/Cancel buttons -->
        <Border DockPanel.Dock="Bottom"
                Padding="16,10"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="Draft auto-saved"
                           VerticalAlignment="Center" FontSize="12" Opacity="0.5"/>
                <Button Grid.Column="1" Content="Cancel" Classes="ghost" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="📤 Send" Classes="accent" Width="100"/>
            </Grid>
        </Border>

        <!-- Compose form -->
        <DockPanel Margin="16,12">
            <!-- From -->
            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
                <TextBlock Text="From" FontSize="12" Opacity="0.6"/>
                <TextBox Watermark="your@email.com"/>
            </StackPanel>

            <!-- To -->
            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
                <TextBlock Text="To" FontSize="12" Opacity="0.6"/>
                <TextBox Watermark="recipient@example.com"/>
            </StackPanel>

            <!-- Cc/Bcc (collapsed by default) -->
            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="+ Cc" Classes="ghost" FontSize="12"/>
                    <Button Content="+ Bcc" Classes="ghost" FontSize="12"/>
                </StackPanel>
            </StackPanel>

            <!-- Subject -->
            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,12">
                <TextBlock Text="Subject" FontSize="12" Opacity="0.6"/>
                <TextBox Watermark="Subject" FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Editor toolbar -->
            <Border DockPanel.Dock="Top"
                    Padding="4,2"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="4"
                    Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button Content="B" FontWeight="Bold" Classes="ghost" Width="32" Height="28"/>
                    <Button Content="I" FontStyle="Italic" Classes="ghost" Width="32" Height="28"/>
                    <Button Content="U" Classes="ghost" Width="32" Height="28"/>
                    <Separator/>
                    <Button Content="🔗" Classes="ghost" Width="32" Height="28" ToolTip.Tip="Insert link"/>
                    <Button Content="😀" Classes="ghost" Width="32" Height="28" ToolTip.Tip="Emoji"/>
                    <Button Content="📷" Classes="ghost" Width="32" Height="28" ToolTip.Tip="Insert image"/>
                    <Separator/>
                    <Button Content="❝" Classes="ghost" Width="32" Height="28" ToolTip.Tip="Quote"/>
                    <Button Content="&lt;&gt;" Classes="ghost" Width="32" Height="28" ToolTip.Tip="Code"/>
                    <Button Content="≡" Classes="ghost" Width="32" Height="28" ToolTip.Tip="List"/>
                </StackPanel>
            </Border>

            <!-- Message body -->
            <TextBox AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Watermark="Write your message..."
                     FontSize="14"
                     MinHeight="200"/>
        </DockPanel>
    </DockPanel>
</Window>
