<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Strider.UI.ViewModels"
             xmlns:domain="using:Strider.Core.Domain"
             x:Class="Strider.UI.Views.CalendarView"
             x:DataType="vm:CalendarViewModel">

    <DockPanel>
        <!-- Header: Month navigation -->
        <Border DockPanel.Dock="Top"
                Padding="12,8"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                <Button Grid.Column="0" Content="◀" Command="{Binding PreviousCommand}" Width="32"/>
                <TextBlock Grid.Column="1" 
                           Text="{Binding CurrentMonth, StringFormat='{}{0:MMMM yyyy}'}"
                           FontWeight="Bold" FontSize="16"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Content="▶" Command="{Binding NextCommand}" Width="32"/>
                <Button Grid.Column="3" Content="Today" Command="{Binding TodayCommand}" Margin="8,0"/>
                <Button Grid.Column="4" Content="➕" Command="{Binding AddEventCommand}" 
                        ToolTip.Tip="Add event" Width="32"/>
            </Grid>
        </Border>

        <!-- View mode tabs -->
        <Border DockPanel.Dock="Top" Padding="12,4">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Content="Month" Classes="ghost" FontSize="12"/>
                <Button Content="Week" Classes="ghost" FontSize="12"/>
                <Button Content="Day" Classes="ghost" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Calendar grid -->
        <Border Padding="8">
            <DockPanel>
                <!-- Day headers -->
                <Border DockPanel.Dock="Top" Margin="0,0,0,4">
                    <Grid ColumnDefinitions="*,*,*,*,*,*,*">
                        <TextBlock Grid.Column="0" Text="Mon" FontWeight="SemiBold" FontSize="12" 
                                   HorizontalAlignment="Center" Opacity="0.6"/>
                        <TextBlock Grid.Column="1" Text="Tue" FontWeight="SemiBold" FontSize="12" 
                                   HorizontalAlignment="Center" Opacity="0.6"/>
                        <TextBlock Grid.Column="2" Text="Wed" FontWeight="SemiBold" FontSize="12" 
                                   HorizontalAlignment="Center" Opacity="0.6"/>
                        <TextBlock Grid.Column="3" Text="Thu" FontWeight="SemiBold" FontSize="12" 
                                   HorizontalAlignment="Center" Opacity="0.6"/>
                        <TextBlock Grid.Column="4" Text="Fri" FontWeight="SemiBold" FontSize="12" 
                                   HorizontalAlignment="Center" Opacity="0.6"/>
                        <TextBlock Grid.Column="5" Text="Sat" FontWeight="SemiBold" FontSize="12" 
                                   HorizontalAlignment="Center" Opacity="0.6"/>
                        <TextBlock Grid.Column="6" Text="Sun" FontWeight="SemiBold" FontSize="12" 
                                   HorizontalAlignment="Center" Opacity="0.6"/>
                    </Grid>
                </Border>

                <!-- Calendar days grid -->
                <ItemsControl ItemsSource="{Binding Days}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="6" Columns="7"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CalendarDay">
                            <Border Margin="1" Padding="4"
                                    Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                    CornerRadius="4"
                                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                    BorderThickness="1">
                                <DockPanel>
                                    <!-- Day number -->
                                    <Border DockPanel.Dock="Top">
                                        <TextBlock Text="{Binding DayNumber}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center">
                                            <TextBlock.Opacity>
                                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                    <Binding Path="IsCurrentMonth"/>
                                                </MultiBinding>
                                            </TextBlock.Opacity>
                                        </TextBlock>
                                    </Border>

                                    <!-- Today indicator -->
                                    <Border DockPanel.Dock="Top"
                                            IsVisible="{Binding IsToday}"
                                            Width="20" Height="2"
                                            Background="{DynamicResource SystemAccentColor}"
                                            CornerRadius="1"
                                            HorizontalAlignment="Center"
                                            Margin="0,2,0,4"/>

                                    <!-- Events -->
                                    <ItemsControl ItemsSource="{Binding Events}" Margin="0,2,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="domain:CalendarEvent">
                                                <Border Padding="2,1" Margin="0,1"
                                                        Background="{DynamicResource SystemAccentColor}"
                                                        CornerRadius="2">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="10"
                                                               Foreground="White"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>
    </DockPanel>
</UserControl>
