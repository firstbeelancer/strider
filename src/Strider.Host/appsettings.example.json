{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Strider": "Debug"
    }
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/strider-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "Database": {
    "Path": "strider.db",
    "CacheSize": 10000
  },
  "Sync": {
    "DefaultMessagesPerFolder": 500,
    "IdleEnabled": true,
    "PollingIntervalMinutes": 5
  },
  "Ai": {
    "Provider": "",
    "Model": "",
    "BaseUrl": "",
    "ApiKeyRef": ""
  },
  "Editor": {
    "DefaultFontFamily": "Inter",
    "DefaultFontSize": 14,
    "Theme": "auto"
  }
}
